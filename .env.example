# ── API Keys ──────────────────────────────────────────────────────────────────
TANKERKOENIG_API_KEY=your_tankerkoenig_api_key_here
EIA_API_KEY=your_eia_api_key_here

# ── Mock data toggle ──────────────────────────────────────────────────────────
# Set to "false" to use live Tankerkönig API (requires TANKERKOENIG_API_KEY)
USE_MOCK_DATA=true

# ── Data paths ────────────────────────────────────────────────────────────────
# In Docker these are bind-mounted to /app/data and /app/notebooks automatically.
# For local dev (running uvicorn outside Docker) set to the absolute project paths:
# DATA_DIR=/path/to/project/data
# NOTEBOOKS_DIR=/path/to/project/notebooks

# ── Setup / Initialisierung ───────────────────────────────────────────────────
# RUN_SETUP_ON_START=true   → Backend baut beim Start automatisch fehlende
#   Komponenten (EDA-Summary, Ölpreise, aktuelle Stationspreise) im Hintergrund.
#   Empfohlen beim ersten Start oder nach git pull der Rohdaten.
RUN_SETUP_ON_START=false

# Pfad zu den Tankerkönig-Rohdaten (prices/YYYY/MM/YYYY-MM-DD-prices.csv).
# Docker: automatisch als /app/data/tankerkoenig-data gemountet (see docker-compose.yml).
# Lokal: absoluter Pfad zum geclonten tankerkoenig-data Repository.
TANKERKOENIG_DATA_PATH=../tankerkoenig-data

# ── Deployment: ports ─────────────────────────────────────────────────────────
# Host ports the containers listen on (point your reverse proxy at these).
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ── Deployment: networking ─────────────────────────────────────────────────────
# BACKEND_URL = base URL the frontend uses to reach the backend.
#   • Leave EMPTY (default) → frontend uses the internal /api proxy (same-origin, no CORS).
#   • Set to the backend subdomain → frontend calls it directly (cross-origin, needs CORS below).
# VITE_ALLOWED_HOSTS = Host headers the Vite dev server accepts (leading dot = all subdomains).
BACKEND_URL=
VITE_ALLOWED_HOSTS=localhost

# ── CORS ─────────────────────────────────────────────────────────────────────
# Must include the frontend origin(s) the browser loads the app from.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── PRODUCTION (jannis-schuler.de) — uncomment these on the server ─────────────
# Frontend: https://predictive-analytics.jannis-schuler.de
# Backend:  https://pred-anal-backend.jannis-schuler.de
# FRONTEND_PORT=3000
# BACKEND_PORT=8000
# BACKEND_URL=https://pred-anal-backend.jannis-schuler.de
# VITE_ALLOWED_HOSTS=.jannis-schuler.de,localhost
# ALLOWED_ORIGINS=https://predictive-analytics.jannis-schuler.de

# ── Guided Terminal: Live-Reload-Schutz ───────────────────────────────────────
# PIN, die der Guided-Terminal-„Reload" (echte Skriptausführung) verlangt.
# Wird serverseitig geprüft. LEER lassen → Live-Reload ist komplett deaktiviert
# (nur die „Demo"-Wiedergabe bleibt für alle nutzbar).
WALKTHROUGH_PIN=

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
PORT=8000

# NOTE: No database required at runtime.
# The app serves all data from joblib models + parquet files.
# database.py / models/models.py / alembic/ are kept as documentation only.
