# ── API Keys ──────────────────────────────────────────────────────────────────
TANKERKOENIG_API_KEY=your_tankerkoenig_api_key_here
EIA_API_KEY=your_eia_api_key_here

# ── Mock data toggle ──────────────────────────────────────────────────────────
# Set to "false" to use live Tankerkönig API (requires TANKERKOENIG_API_KEY)
USE_MOCK_DATA=true

# ── Data paths ────────────────────────────────────────────────────────────────
# In Docker these are bind-mounted to /app/data and /app/notebooks automatically.
# For local dev (running uvicorn outside Docker) set to the absolute project paths:
# DATA_DIR=/path/to/project/data
# NOTEBOOKS_DIR=/path/to/project/notebooks

# ── Setup / Initialisierung ───────────────────────────────────────────────────
# RUN_SETUP_ON_START=true   → Backend baut beim Start automatisch fehlende
#   Komponenten (EDA-Summary, Ölpreise, aktuelle Stationspreise) im Hintergrund.
#   Empfohlen beim ersten Start oder nach git pull der Rohdaten.
RUN_SETUP_ON_START=false

# Pfad zu den Tankerkönig-Rohdaten (prices/YYYY/MM/YYYY-MM-DD-prices.csv).
# Docker: automatisch als /app/data/tankerkoenig-data gemountet (see docker-compose.yml).
# Lokal: absoluter Pfad zum geclonten tankerkoenig-data Repository.
TANKERKOENIG_DATA_PATH=../tankerkoenig-data

# ── CORS ─────────────────────────────────────────────────────────────────────
# Add your Cloudflare Tunnel domain if you expose the app publicly:
# ALLOWED_ORIGINS=http://localhost:3000,https://xyz.trycloudflare.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
PORT=8000

# NOTE: No database required at runtime.
# The app serves all data from joblib models + parquet files.
# database.py / models/models.py / alembic/ are kept as documentation only.
