# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/spritpreis_analytics

# API Keys
TANKERKOENIG_API_KEY=your_tankerkoenig_api_key_here
EIA_API_KEY=your_eia_api_key_here

# Application Settings
DEBUG=True
ENVIRONMENT=development
SECRET_KEY=your_secret_key_here

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Scheduled Jobs
DATA_FETCH_INTERVAL=3600  # seconds (1 hour)
MODEL_RETRAIN_INTERVAL=86400  # seconds (24 hours)

# ML Model Settings
PROPHET_CHANGEPOINT_PRIOR_SCALE=0.05
LSTM_EPOCHS=100
LSTM_BATCH_SIZE=32

# Logging
LOG_LEVEL=INFO
