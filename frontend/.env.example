# ── Setup-Wizard ─────────────────────────────────────────────────────────────
# VITE_SHOW_SETUP=true  → Zeigt beim ersten App-Start den Setup-Wizard,
#   wenn noch scriptbare Komponenten fehlen (EDA, Ölpreise, aktuelle Preise).
#   Setzt man auf false/leer → kein Wizard, App startet direkt.
VITE_SHOW_SETUP=false

# ── API Base URL ──────────────────────────────────────────────────────────────
# Leer lassen wenn Vite-Proxy (/api → backend:8000) aktiv ist (docker-compose).
# VITE_API_URL=http://localhost:8000
