   "source": [
    "---\n",
    "## Phase 3 — Data Preparation\n",
    "\n",
    "Der `GeoDataLoader` lädt alle BW-Stationen, berechnet Geo-Features und baut  \n",
    "einen **Panel-Datensatz** auf: eine Zeile = (Zeitstempel × Station).\n",
    "\n",
    "**Feature-Gruppen:**\n",
    "```\n",
    "Zeitreihe  : lag_1h … lag_168h, roll_mean/std_6/24/48h, trend, momentum, price_t, diff\n",
    "Temporal   : hour_sin/cos, dow_sin/cos, is_weekend, is_holiday\n",
    "Statisch   : latitude, longitude, competitor_count_2km, nearest_competitor_km,\n",
    "             is_autobahn, brand_encoded\n",
    "```"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "load_data",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Daten laden ──────────────────────────────────────────────────────────────\n",
    "# start_date='2022-01-01' hält den Cache klein (~2 Jahre);\n",
    "# für vollständige Analyse auf '2020-01-01' oder None setzen.\n",
    "FUEL_TYPE = 'diesel'\n",
    "START_DATE = '2022-01-01'\n",
    "FORECAST_HORIZON = 72\n",
    "\n",
    "loader = GeoDataLoader(\n",
    "    mode='bw',\n",
    "    start_date=START_DATE,\n",
    "    forecast_horizon=FORECAST_HORIZON,\n",
    "    fuel_type=FUEL_TYPE,\n",
    "    cache=True,\n",
    "    debug=True,\n",
    ")\n",
    "X, y = loader.load()\n",
    "print(f'\\nX shape : {X.shape}  (rows = Zeitstempel × Stationen)')\n",
    "print(f'y shape : {y.shape}  (Spalten = t+1h … t+{FORECAST_HORIZON}h)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "feature_overview",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Feature-Matrix Überblick ─────────────────────────────────────────────────\n",
    "feature_cols = [c for c in X.columns if c != 'station_uuid']\n",
    "geo_cols     = ['latitude', 'longitude', 'competitor_count_2km',\n",
    "                'nearest_competitor_km', 'is_autobahn', 'brand_encoded']\n",
    "ts_cols      = [c for c in feature_cols if c not in geo_cols]\n",
    "\n",
    "print(f'Gesamt-Features       : {len(feature_cols)}')\n",
    "print(f'  Zeitreihen-Features : {len(ts_cols)}')\n",
    "print(f'  Geo-Features        : {len(geo_cols)}')\n",
    "print(f'\\nBrand-Encoding (Ø Preis je Marke, aus Trainingsperiode):')\n",
    "if loader.brand_mean_map:\n",
    "    bm = {k: round(v, 4) for k, v in loader.brand_mean_map.items() if k != '__mean__'}\n",
    "    for brand, val in sorted(bm.items(), key=lambda x: x[1]):\n",
    "        print(f'  {brand:<20} {val:.4f} €/L')\n",
    "print(f'\\nStichprobe Feature-Matrix:')\n",
    "X[feature_cols].describe().round(4)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "train_test_split",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Temporaler Split ─────────────────────────────────────────────────────────\n",
    "print('Temporaler Split (kein Shuffle — Zeitreihe!):')\n",
    "X_train, X_val, X_test, y_train, y_val, y_test = loader.train_val_test_split(X, y)\n",
    "\n",
    "# station_uuid aus Feature-Matrix herausnehmen (nicht für Training)\n",
    "X_train_f = X_train[feature_cols]\n",
    "X_val_f   = X_val[feature_cols]\n",
    "X_test_f  = X_test[feature_cols]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "scaling",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Skalierung ───────────────────────────────────────────────────────────────\n",
    "scaler_X = StandardScaler()\n",
    "scaler_y = StandardScaler()\n",
    "\n",
    "X_train_sc = scaler_X.fit_transform(X_train_f)\n",
    "X_val_sc   = scaler_X.transform(X_val_f)\n",
    "X_test_sc  = scaler_X.transform(X_test_f)\n",
    "\n",
    "y_train_sc = scaler_y.fit_transform(y_train.values)\n",
    "\n",
    "print('Scaler auf Trainingsdaten gefittet.')\n",
    "print(f'X_train_sc : {X_train_sc.shape}')\n",
    "print(f'y_train_sc : {y_train_sc.shape}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "phase4_header",
   "metadata": {},
   "source": [
    "---\n",
    "## Phase 4 — Modelling\n",
    "\n",
    "Zwei Modelle im direkten Vergleich:\n",
    "\n",
    "| | Baseline | Angereichert |\n",
    "|---|---|---|\n",
    "| Features | nur Zeitreihe + Temporal | + Geo-Features |\n",
    "| Architektur | (256, 128) | (256, 128) |\n",
    "| Ausgabe | t+1h … t+72h | t+1h … t+72h |\n",
    "\n",
    "> Architektur `(256, 128)` wurde in `spedition_mlp.ipynb` als beste validiert."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "train_baseline",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Baseline: nur Zeitreihe + Temporal ───────────────────────────────────────\n",
    "scaler_X_base = StandardScaler()\n",
    "X_train_base_sc = scaler_X_base.fit_transform(X_train[ts_cols])\n",
    "X_val_base_sc   = scaler_X_base.transform(X_val[ts_cols])\n",
    "X_test_base_sc  = scaler_X_base.transform(X_test[ts_cols])\n",
    "\n",
    "print('Training Baseline MLP (keine Geo-Features) …')\n",
    "model_base = train_mlp(X_train_base_sc, y_train_sc, hidden_layer_sizes=(256, 128))\n",
    "print(f'  Iterationen: {model_base.n_iter_}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "train_enriched",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Angereichertes Modell: Zeitreihe + Geo ────────────────────────────────────\n",
    "print('Training angereichertes MLP (mit Geo-Features) …')\n",
    "model_geo = train_mlp(X_train_sc, y_train_sc, hidden_layer_sizes=(256, 128))\n",
    "print(f'  Iterationen: {model_geo.n_iter_}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "arch_comparison",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Architektur-Vergleich (angereicherte Features) ─────────────────────────────\n",
    "ARCHITECTURES = [(64,), (128, 64), (256, 128), (512, 256, 128)]\n",
    "\n",
    "print('Architektur-Vergleich (Val MAE, angereicherte Features):')\n",
    "comparison_df = run_architecture_comparison(\n",
    "    ARCHITECTURES,\n",
    "    X_train_sc, y_train_sc,\n",
    "    X_val_sc, y_val.values,\n",
    "    scaler_y,\n",
    ")\n",
    "comparison_df"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "phase5_header",
   "metadata": {},
   "source": [
    "---\n",
    "## Phase 5 — Evaluation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "eval_val",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Validation Set: Baseline vs. Angereichert ─────────────────────────────────\n",
    "res_base = evaluate_model(model_base, X_val_base_sc, y_val.values, scaler_y, 'Baseline (Val)')\n",
    "res_geo  = evaluate_model(model_geo,  X_val_sc,      y_val.values, scaler_y, 'Geo-MLP  (Val)')\n",
    "\n",
    "print('\\n── Direkter Vergleich ─────────────────────────────────────')\n",
    "print(f'  Baseline  MAE: {res_base[\"mae\"]:.5f} €/L   R²: {res_base[\"r2\"]:.4f}')\n",
    "print(f'  Geo-MLP   MAE: {res_geo[\"mae\"]:.5f} €/L   R²: {res_geo[\"r2\"]:.4f}')\n",
    "delta = res_base['mae'] - res_geo['mae']\n",
    "pct   = delta / res_base['mae'] * 100\n",
    "print(f'  Verbesserung : {delta:+.5f} €/L  ({pct:+.1f} %)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "eval_by_horizon",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── MAE je Horizont ───────────────────────────────────────────────────────────\n",
    "y_pred_base = scaler_y.inverse_transform(model_base.predict(X_val_base_sc))\n",
    "y_pred_geo  = scaler_y.inverse_transform(model_geo.predict(X_val_sc))\n",
    "\n",
    "y_pred_base_df = pd.DataFrame(y_pred_base, index=y_val.index, columns=y_val.columns)\n",
    "y_pred_geo_df  = pd.DataFrame(y_pred_geo,  index=y_val.index, columns=y_val.columns)\n",
    "\n",
    "# single-station target prefix (reuse compute_metrics_by_horizon with synthetic base_targets)\n",
    "from sklearn.metrics import mean_absolute_error\n",
    "mae_base_per_step = []\n",
    "mae_geo_per_step  = []\n",
    "for step in range(1, FORECAST_HORIZON + 1):\n",
    "    col = f't+{step}h'\n",
    "    mae_base_per_step.append(mean_absolute_error(y_val[col], y_pred_base_df[col]))\n",
    "    mae_geo_per_step.append( mean_absolute_error(y_val[col], y_pred_geo_df[col]))\n",
    "\n",
    "steps = list(range(1, FORECAST_HORIZON + 1))\n",
    "fig, ax = plt.subplots(figsize=(12, 4))\n",
    "ax.plot(steps, mae_base_per_step, label='Baseline (keine Geo)', color='steelblue', linewidth=1.5)\n",
    "ax.plot(steps, mae_geo_per_step,  label='Geo-MLP',              color='crimson',   linewidth=1.5)\n",
    "ax.set_xlabel('Horizont (Stunden)')\n",
    "ax.set_ylabel('MAE €/L')\n",
    "ax.set_title('Vorhersagefehler je Horizont — Baseline vs. Geo-MLP')\n",
    "ax.legend()\n",
    "ax.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "feature_importance",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Permutation Feature Importance (Val-Set, Ø über alle Horizonte) ───────────\n",
    "from sklearn.inspection import permutation_importance\n",
    "\n",
    "print('Berechne Permutation Importance (kann 1–2 Min dauern) …')\n",
    "perm = permutation_importance(\n",
    "    model_geo, X_val_sc, y_val.values,\n",
    "    n_repeats=5, random_state=42, n_jobs=-1,\n",
    "    scoring='neg_mean_absolute_error',\n",
    ")\n",
    "\n",
    "importance_df = pd.DataFrame({\n",
    "    'feature':    feature_cols,\n",
    "    'importance': perm.importances_mean,\n",
    "    'std':        perm.importances_std,\n",
    "}).sort_values('importance', ascending=False)\n",
    "\n",
    "print('\\nTop-20 wichtigste Features:')\n",
    "print(importance_df.head(20).to_string(index=False))\n",
    "\n",
    "# Highlight geo features\n",
    "print('\\nGeo-Features Rang:')\n",
    "print(importance_df[importance_df['feature'].isin(geo_cols)].to_string(index=False))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "importance_plot",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Feature Importance Plot (Top 25) ──────────────────────────────────────────\n",
    "top25 = importance_df.head(25).iloc[::-1]\n",
    "colors = ['crimson' if f in geo_cols else 'steelblue' for f in top25['feature']]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(9, 8))\n",
    "bars = ax.barh(top25['feature'], top25['importance'], xerr=top25['std'],\n",
    "               color=colors, alpha=0.85, capsize=3)\n",
    "ax.set_xlabel('Permutation Importance (neg. MAE-Abnahme)')\n",
    "ax.set_title('Top-25 Features — Geo in Rot')\n",
    "\n",
    "from matplotlib.patches import Patch\n",
    "ax.legend(handles=[\n",
    "    Patch(color='steelblue', label='Zeitreihe / Temporal'),\n",
    "    Patch(color='crimson',   label='Geo-Feature'),\n",
    "])\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "brand_effect",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Marken-Effekt: medianer Preis je Marke ────────────────────────────────────\n",
    "if loader.brand_mean_map:\n",
    "    bm_clean = {k: v for k, v in loader.brand_mean_map.items() if k != '__mean__'}\n",
    "    brand_series = pd.Series(bm_clean).sort_values()\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(10, 5))\n",
    "    colors_brand = ['crimson' if v > brand_series.mean() else 'steelblue'\n",
    "                    for v in brand_series]\n",
    "    brand_series.plot(kind='barh', ax=ax, color=colors_brand, alpha=0.8)\n",
